PORT=3000
FRONTEND_ORIGIN=http://localhost:4200

# postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL=postgresql://postgres:local_password_here@localhost:5432/scaffold_db

# Firebase project ID. "demo-scaffold" runs against the local Auth emulator (pnpm dev starts it
# automatically) with no real Firebase project required. Must match the frontend's projectId.
FIREBASE_PROJECT_ID=demo-scaffold

# Only required for a real Firebase project (Project Settings > Service Accounts > Generate new
# private key) — leave blank when using the emulator.
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Points the Admin SDK at the local Auth emulator instead of real Firebase. Remove this to use a
# real Firebase project (FIREBASE_CLIENT_EMAIL/FIREBASE_PRIVATE_KEY become required).
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
