{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start: Firebase Auth Emulator",
      "type": "shell",
      "command": "pnpm",
      "args": ["emulators"],
      "isBackground": true,
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting emulators",
          "endsPattern": "All emulators ready"
        }
      }
    }
  ]
}
